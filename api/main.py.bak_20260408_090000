                post_replies = replies_store.get(post_id, [])
                
                return {
                    "success": True, 
                    "data": {
                        "post": {
                            "id": post.get('id'),
                            "ai_id": post.get('ai_id'),
                            "ai_name": name,
                            "avatar_emoji": avatar,
                            "ai_avatar": avatar,
                            "post_type": post.get('post_type', 'trade'),
                            "title": post.get('content', '')[:50],
                            "content": post.get('content', ''),
                            "created_at": post.get('timestamp'),
                            "reply_count": len(post_replies),
                            "likes": 0,
                            "views": 0
                        }, 
                        "replies": post_replies
                    }
                }
        
        # 如果BBS系统找不到，尝试从交易记录查找
        trades = await db_manager.get_recent_trades_all(limit=1000)
        for trade in trades:
            if str(trade.get('id')) == str(post_id):
                character = get_character(trade.get('ai_id', ''))
                avatar = character.avatar if character else '🤖'
                name = character.name if character else trade.get('ai_name', 'AI选手')
                
                action_text = "买入" if trade.get('action') == 'buy' else "卖出"
                content = f"{action_text} {trade.get('name', '')}({trade.get('symbol', '')}) {trade.get('quantity', 0)}股，价格{trade.get('price', 0)}元。{trade.get('reason', '')}"
                
                post_replies = replies_store.get(post_id, [])
                
                post = {
                    "id": trade.get('id'),
                    "ai_id": trade.get('ai_id'),
                    "ai_name": name,
                    "avatar_emoji": avatar,
                    "ai_avatar": avatar,
                    "post_type": "trade",
                    "title": content,
                    "content": content,
                    "created_at": trade.get('trade_time'),
                    "reply_count": len(post_replies),
                    "likes": 0,
                    "views": 0
                }
                return {"success": True, "data": {"post": post, "replies": post_replies}}
        
        return {"success": False, "error": "帖子不存在"}
    except Exception as e:
        logger.error(f"获取帖子详情失败: {e}")
        return {"success": False, "error": str(e)}



def calculate_win_streak(portfolio) -> int:
    """计算连胜天数（基于持仓浮动盈亏）"""
    if not portfolio.holdings:
        return 0
    total_pnl = sum(h.unrealized_pnl for h in portfolio.holdings)
    if total_pnl > 5000:
        return 3
    elif total_pnl > 1000:
        return 2
    elif total_pnl > 0:
        return 1
    else:
        return 0


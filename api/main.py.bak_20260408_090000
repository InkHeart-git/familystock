@app.websocket("/ws")
async def websocket_endpoint(websocket: WebSocket):
    """WebSocket 连接"""
    await manager.connect(websocket)
    
    try:
        # 发送初始数据
        characters = []
        for char_id, char in get_all_characters().items():
            portfolio = await portfolio_manager.load_portfolio(char_id)
            characters.append({
                "id": char_id,
                "name": char.name,
                "avatar": char.avatar,
                "style": char.style,
                "total_value": portfolio.total_value,
                "cash": portfolio.cash,
                "holdings_count": len(portfolio.holdings)
            })
        
        await websocket.send_json({
            "type": "init",
            "channel": "characters",
            "data": {"characters": characters}
        })
        
        # 发送最近帖子
        recent_posts = bbs_system.get_all_posts(20)
        await websocket.send_json({
            "type": "init",
            "channel": "bbs",
            "data": {"posts": recent_posts}
        })
        
        # 处理消息
        while True:
            data = await websocket.receive_json()
            
            if data.get("type") == "ping":
                await websocket.send_json({
                    "type": "pong",
                    "timestamp": datetime.now().isoformat()
                })
            
            elif data.get("type") == "get_portfolio":
                ai_id = data.get("ai_id")
                if ai_id:
                    portfolio = await portfolio_manager.load_portfolio(ai_id)
                    character = get_character(ai_id)
                    await websocket.send_json({
                        "type": "portfolio",
                        "data": {
                            "ai_id": ai_id,
                            "ai_name": character.name if character else ai_id,
                            "total_value": portfolio.total_value,
                            "cash": portfolio.cash,
                            "holdings": [
                                {
                                    "symbol": h.symbol,
                                    "name": h.name,
                                    "quantity": h.quantity,
                                    "buy_price": h.buy_price,
                                    "current_price": h.current_price,
                                    "unrealized_pnl": h.unrealized_pnl,
                                    "unrealized_pnl_pct": h.unrealized_pnl_pct
                                }
                                for h in portfolio.holdings
                            ]
                        }
                    })
    
    except WebSocketDisconnect:
        manager.disconnect(websocket)
    except Exception as e:
        logger.error(f"WebSocket 错误: {e}")
        manager.disconnect(websocket)



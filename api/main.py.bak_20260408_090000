    try:
        content = request.get("content", "")
        user_type = request.get("user_type", "human")
        user_id = request.get("user_id", "guest")
        
        # 保存回复到内存
        if post_id not in replies_store:
            replies_store[post_id] = []
        
        reply = {
            "id": len(replies_store[post_id]) + 1,
            "post_id": post_id,
            "content": content,
            "user_type": user_type,
            "user_id": user_id,
            "created_at": datetime.now().isoformat()
        }
        replies_store[post_id].append(reply)
        

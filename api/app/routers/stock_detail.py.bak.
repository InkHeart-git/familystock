@router_stock_detail.get("/news/{ts_code}")
async def get_stock_news(ts_code: str, limit: int = Query(20, description="返回条数")):
    """获取股票相关新闻和公告"""
    try:
        ts_code = format_ts_code(ts_code)
        symbol = ts_code.split(".")[0]
        conn = get_db_connection()
        cursor = conn.cursor(pymysql.cursors.DictCursor)
        
        # 获取公司公告
        cursor.execute("""
        SELECT * FROM stock_announcement 
        WHERE ts_code = %s 
        ORDER BY ann_date DESC 
        LIMIT %s
        """, (ts_code, limit//2))
        announcements = cursor.fetchall()
        
        # 获取相关新闻
        cursor.execute("""
        SELECT * FROM stock_news 
        WHERE title LIKE %s OR content LIKE %s
        ORDER BY published_at DESC 
        LIMIT %s
        """, (f"%{symbol}%", f"%{symbol}%", limit//2))
        news = cursor.fetchall()
        
        cursor.close()
        conn.close()
        
        return {
            "announcements": [
                {
                    "ann_date": item.get("ann_date"),
                    "title": item.get("ann_title"),
                    "content": item.get("ann_content"),
                    "type": item.get("ann_type")
                } for item in announcements
            ],
            "news": [
                {
                    "published_at": item.get("published_at"),
                    "title": item.get("title"),
                    "content": item.get("content"),
                    "source": item.get("source")
                } for item in news
            ],
            "announcement_count": len(announcements),
            "news_count": len(news)
        }
        
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"获取新闻公告失败: {str(e)}")

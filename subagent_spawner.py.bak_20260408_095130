        return None
    
    char = AI_CHARACTERS[ai_id]
    result = {'ai_id': ai_id, 'name': char['name'], 'style': char['style'], 'success': False}
    
    # 1. 获取持仓数据
    holdings = get_ai_holdings()
    ai_holdings = holdings.get(ai_id, [])
    
    # 2. 获取市场数据
    market_data = await get_market_data()
    indices_str = '\n'.join(market_data['indices']) or '暂无数据'
    
    # 3. 构建持仓信息
    holdings_str = ""
    if ai_holdings:
        holdings_str = "我的持仓：\n"
        for h in ai_holdings:
            holdings_str += f"- {h['name']}({h['symbol']}): {h['qty']}股 @ {h['price']}元\n"
    else:
        holdings_str = "（当前无持仓，需要寻找新标的）"
    
    # 4. 判断当前交易阶段
    now = datetime.now()
    time_str = now.strftime("%Y年%m月%d日 %H:%M")
    hour = now.hour
    if 9 <= hour < 11.5:
        trade_phase = "上午盘中"
    elif 11.5 <= hour < 13:
        trade_phase = "午间休市"
    elif 13 <= hour < 15:
        trade_phase = "下午盘中"
    elif hour >= 15:
        trade_phase = "收盘后"
    else:
        trade_phase = "非交易时段"
    
    # 发帖类型
    if 9 <= hour < 10:
        post_type = "开盘前分析"
    elif hour >= 15:
        post_type = "收盘总结"
    else:
        post_type = "盘中观察"
    
    # 5. 构建分析Prompt - 必须基于持仓 (包含完整上下文)
    analysis_prompt = f"""【重要上下文】
- 当前时间：{time_str}
- 交易阶段：{trade_phase}
- 发帖类型：{post_type}

【市场状况】
{indices_str}

【你的持仓】
{holdings_str}

【你的角色】
你是{char['name']}，投资风格：{char['style']}。
性格特点：{char['personality']}

【分析要求】
请结合你的持仓和当前交易阶段，分析市场：
1. 分析你持仓股票的走势和当前盈亏
2. 根据交易阶段调整内容：
   - 开盘前：重点说开盘预期、操作计划
   - 盘中：重点说实时应对、盘中决策
   - 收盘后：重点说收盘分析、明日展望
3. 持仓相关的操作计划（加仓/减仓/持有）

【重要提醒】
- 必须基于当前交易阶段调整发言内容！
- 不要提及未来才会发生的事件（如节假日的促销数据）
- 可以提及美股/港股作为市场参考（如"特斯拉下跌影响比亚迪"），但必须明确这只是参考！
- 你的持仓和交易决策只能基于A股！
- 必须围绕你的持仓来分析！
- 直接输出，不要客套话。"""
    
    # 5. 调用DeepSeek LLM分析
    print(f"[{char['name']}] 🔍 DeepSeek LLM分析（基于持仓）...")
    analysis = await call_deepseek(char['system_prompt'], analysis_prompt)
    
    if not analysis:
        print(f"[{char['name']}] ❌ LLM调用失败")
        return result
    
    result['analysis'] = analysis
    
    # 6. 生成帖子
    post_prompt = f"""基于以下持仓分析，生成一条{post_type}帖子（80字以内）：
持仓：{holdings_str}
分析：{analysis}

用你的风格（{char['style']}），口语化，自然。不要用AI的语气。
帖子标题要包含持仓股票名称！"""

    post = await call_deepseek(char['system_prompt'], post_prompt)
    
    if post:
        # 添加标题和标签
        holding_names = ', '.join([h['name'] for h in ai_holdings]) if ai_holdings else '暂无持仓'
        full_post = f"""【{char['name']} · {post_type}】

{post}

{'-'*40}
📊 持仓：{holding_names}
{'-'*40}
#持仓 #每日看盘"""
        
        if save_to_bbs(ai_id, full_post):
            result['post_content'] = post
            result['success'] = True
            print(f"[{char['name']}] ✅ 完成并保存到BBS")
    else:
        print(f"[{char['name']}] ⚠️ 帖子生成失败")
    
    return result


# 环境变量配置示例
# 复制此文件为 .env 并填入你的实际配置

# 应用环境
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=familystock
DB_PASSWORD=changeme
DB_NAME=familystock

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT密钥 (生产环境请使用强密码)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# API密钥
OPENAI_API_KEY=sk-your-openai-api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
TUSHARE_TOKEN=your-tushare-token

# 端口配置
API_PORT=5000
FRONTEND_PORT=3000
DB_PORT=5432
REDIS_PORT=6379
NGINX_PORT=80
NGINX_SSL_PORT=443

# 股票数据源配置
# 可选: tushare(国内), alpha_vantage(国际), yahoo
STOCK_DATA_PROVIDER=tushare

# AI模型配置
AI_MODEL_PROVIDER=openai
AI_MODEL=gpt-4

<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<script></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ministone - 投资模拟平台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #1E5F8E;
            --primary-dark: #164A6E;
            --primary-light: #4A8FBF;
            --success: #10B981;
            --warning: #F59E0B;
            --danger: #EF4444;
            --bg-dark: #0a0a0f;
            --bg-card: #16213e;
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 100%);
            min-height: 100vh;
            color: #fff;
        }
        
        /* 登录/注册页面 */
        .auth-page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: radial-gradient(ellipse at top, #1a1a2e 0%, #0a0a0f 70%);
        }
        
        .logo-container {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .logo {
            font-size: 64px;
            margin-bottom: 16px;
            animation: float 3s ease-in-out infinite;
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        
        .brand-name {
            font-size: 32px;
            font-weight: 800;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 2px;
        }
        
        .tagline {
            font-size: 14px;
            color: #8892b0;
            margin-top: 8px;
        }
        
        .auth-card {
            width: 100%;
            max-width: 400px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 32px;
        }
        
        .auth-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 24px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 4px;
        }
        
        .auth-tab {
            flex: 1;
            padding: 12px;
            text-align: center;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 500;
            color: #8892b0;
        }
        
        .auth-tab.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        
        .form-group {
            margin-bottom: 16px;
        }
        
        .form-label {
            display: block;
            font-size: 14px;
            color: #8892b0;
            margin-bottom: 8px;
        }
        
        .form-input {
            width: 100%;
            padding: 14px 16px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: white;
            font-size: 16px;
            outline: none;
            transition: all 0.3s;
        }
        
        .form-input:focus {
            border-color: #667eea;
            background: rgba(255, 255, 255, 0.08);
        }
        
        .form-input::placeholder {
            color: #64748b;
        }
        
        .input-hint {
            font-size: 12px;
            color: #64748b;
            margin-top: 6px;
        }
        
        .input-hint.error {
            color: #ef4444;
        }
        
        .input-hint.success {
            color: #10b981;
        }
        
        .btn-primary {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 8px;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
        }
        
        .btn-primary:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }
        
        /* 主页样式 */
        .home-page {
            display: none;
            min-height: 100vh;
            padding-bottom: 80px;
        }
        
        .home-header {
            background: linear-gradient(135deg, #1E5F8E 0%, #164A6E 100%);
            padding: 20px 20px 30px;
            border-radius: 0 0 24px 24px;
        }
        
        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .header-title {
            font-size: 20px;
            font-weight: 600;
        }
        
        .header-actions {
            display: flex;
            gap: 16px;
        }
        
        .header-icon {
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .header-icon:hover {
            background: rgba(255, 255, 255, 0.2);
        }
        
        /* 快捷入口 */
        .quick-actions {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            padding: 0 20px;
            margin-bottom: 20px;
        }
        
        .quick-action-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 16px;
            padding: 16px 8px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .quick-action-card:hover {
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-2px);
        }
        
        .quick-action-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 8px;
            font-size: 24px;
            background: linear-gradient(135deg, #1E5F8E 0%, #4A8FBF 100%);
            color: white;
        }
        
        .quick-action-label {
            font-size: 12px;
            font-weight: 500;
            color: #fff;
        }
        
        /* 市场大盘 */
        .market-section {
            padding: 20px;
        }
        
        .section-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .market-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }
        
        .market-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 16px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .market-card:hover {
            background: rgba(255, 255, 255, 0.08);
            transform: translateY(-2px);
        }
        
        .market-name {
            font-size: 13px;
            color: #8892b0;
            margin-bottom: 8px;
        }
        
        .market-value {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 6px;
        }
        
        .market-change {
            font-size: 12px;
            font-weight: 600;
            padding: 4px 8px;
            border-radius: 4px;
            display: inline-block;
        }
        
        .market-change.up {
            background: rgba(239, 68, 68, 0.2);
            color: #ff6b6b;
        }
        
        .market-change.down {
            background: rgba(16, 185, 129, 0.2);
            color: #51cf66;
        }
        
        /* 新闻区域 */
        .news-section {
            padding: 0 20px 20px;
        }
        
        .news-tabs {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
            overflow-x: auto;
            padding-bottom: 4px;
        }
        
        .news-tab {
            padding: 8px 16px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s;
            white-space: nowrap;
        }
        
        .news-tab.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-color: transparent;
        }
        
        .news-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        .news-item {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 16px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .news-item:hover {
            background: rgba(255, 255, 255, 0.08);
        }
        
        .news-tag {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 8px;
        }
        
        .news-tag.black-swan {
            background: rgba(239, 68, 68, 0.2);
            color: #ff6b6b;
        }
        
        .news-tag.gray-rhino {
            background: rgba(245, 158, 11, 0.2);
            color: #f59e0b;
        }
        
        .news-tag.hot {
            background: rgba(59, 130, 246, 0.2);
            color: #3b82f6;
        }
        
        .news-title {
            font-size: 15px;
            font-weight: 500;
            line-height: 1.5;
            margin-bottom: 8px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        .news-meta {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: #64748b;
        }
        
        /* 风险提示弹窗 */
        .risk-modal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(10px);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s;
        }
        
        .risk-modal.show {
            opacity: 1;
            visibility: visible;
        }
        
        .risk-modal-content {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 24px;
            width: 100%;
            max-width: 420px;
            max-height: 80vh;
            overflow-y: auto;
            padding: 32px;
            position: relative;
        }
        
        .risk-icon {
            font-size: 64px;
            text-align: center;
            margin-bottom: 20px;
        }
        
        .risk-title {
            font-size: 24px;
            font-weight: 700;
            text-align: center;
            color: #ff6b6b;
            margin-bottom: 8px;
        }
        
        .risk-subtitle {
            text-align: center;
            color: #8892b0;
            margin-bottom: 24px;
            font-size: 14px;
        }
        
        .risk-content {
            background: rgba(239, 68, 68, 0.1);
            border-left: 4px solid #ef4444;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 24px;
        }
        
        .risk-content h4 {
            font-size: 14px;
            margin-bottom: 12px;
            color: #fca5a5;
        }
        
        .risk-content ul {
            font-size: 13px;
            color: #e2e8f0;
            line-height: 1.8;
            padding-left: 16px;
        }
        
        .risk-content li {
            margin-bottom: 8px;
        }
        
        .risk-actions {
            display: flex;
            gap: 12px;
        }
        
        .btn-agree {
            flex: 1;
            padding: 16px;
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-agree:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(239, 68, 68, 0.4);
        }
        
        .btn-disagree {
            flex: 1;
            padding: 16px;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-disagree:hover {
            background: rgba(255, 255, 255, 0.15);
        }
        
        /* Toast提示 */
        .toast {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%) translateY(-100px);
            background: #1F2937;
            color: white;
            padding: 12px 24px;
            border-radius: 12px;
            font-size: 14px;
            z-index: 10000;
            opacity: 0;
            transition: all 0.3s;
        }
        
        .toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }
        
        .toast.success { border: 1px solid #10b981; }
        .toast.error { border: 1px solid #ef4444; }
        
        /* 加载动画 */
        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin-right: 8px;
            vertical-align: middle;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* 隐藏类 */
        .hidden { display: none !important; }
        
        /* 密码强度指示 */
        .password-strength {
            display: flex;
            gap: 4px;
            margin-top: 8px;
        }
        
        .strength-bar {
            flex: 1;
            height: 4px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 2px;
            transition: all 0.3s;
        }
        
        .strength-bar.weak { background: #ef4444; }
        .strength-bar.medium { background: #f59e0b; }
        .strength-bar.strong { background: #10b981; }
        
        /* ==================== 移动端适配 ==================== */
        @media (max-width: 480px) {
            .auth-card {
                padding: 24px 20px;
                border-radius: 20px;
            }
            
            .brand-name {
                font-size: 28px;
            }
            
            .logo {
                font-size: 48px;
            }
            
            .form-input {
                padding: 14px 16px;
                font-size: 16px; /* 防止iOS缩放 */
            }
            
            .btn-primary {
                padding: 16px;
                font-size: 16px;
            }
            
            .home-header {
                padding: 16px;
                border-radius: 0 0 20px 20px;
            }
            
            .header-title {
                font-size: 16px;
            }
            
            .header-icon {
                width: 36px;
                height: 36px;
            }
            
            .market-section {
                padding: 16px;
            }
            
            .market-grid {
                grid-template-columns: repeat(3, 1fr);
                gap: 8px;
            }
            
            .market-card {
                padding: 12px 8px;
                border-radius: 12px;
            }
            
            .market-name {
                font-size: 11px;
            }
            
            .market-value {
                font-size: 16px;
            }
            
            .market-change {
                font-size: 11px;
                padding: 3px 6px;
            }
            
            .news-section {
                padding: 0 16px 100px; /* 底部留出导航栏空间 */
            }
            
            .news-tabs {
                gap: 8px;
            }
            
            .news-tab {
                padding: 6px 12px;
                font-size: 12px;
            }
            
            .news-item {
                padding: 14px;
            }
            
            .news-title {
                font-size: 14px;
            }
            
            /* 底部导航栏 */
            .bottom-nav {
                display: flex;
                position: fixed;
                bottom: 0;
                left: 0;
                right: 0;
                background: rgba(22, 33, 62, 0.95);
                backdrop-filter: blur(10px);
                border-top: 1px solid rgba(255, 255, 255, 0.1);
                padding: 8px 0;
                z-index: 1000;
            }
            
            .nav-item {
                flex: 1;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 4px;
                padding: 4px;
                cursor: pointer;
                transition: all 0.3s;
            }
            
            .nav-item.active {
                color: #667eea;
            }
            
            .nav-item:not(.active) {
                color: #64748b;
            }
            
            .nav-icon {
                font-size: 20px;
            }
            
            .nav-label {
                font-size: 11px;
            }
            
            /* 持仓页面 */
            .portfolio-section {
                padding: 16px 16px 100px;
            }
            
            .portfolio-header {
                background: linear-gradient(135deg, rgba(102, 126, 234, 0.3) 0%, rgba(118, 75, 162, 0.3) 100%);
                border-radius: 16px;
                padding: 20px;
                margin-bottom: 20px;
            }
            
            .portfolio-value {
                font-size: 32px;
                font-weight: 700;
                margin-bottom: 8px;
            }
            
            .portfolio-label {
                font-size: 13px;
                color: #8892b0;
            }
            
            .portfolio-change {
                display: inline-flex;
                align-items: center;
                gap: 4px;
                padding: 6px 12px;
                border-radius: 20px;
                font-size: 14px;
                font-weight: 600;
                margin-top: 12px;
            }
            
            .portfolio-change.up {
                background: rgba(239, 68, 68, 0.2);
                color: #ff6b6b;
            }
            
            .portfolio-change.down {
                background: rgba(16, 185, 129, 0.2);
                color: #51cf66;
            }
        }
        
        @media (min-width: 481px) {
            .bottom-nav {
                display: none;
            }
        }
    </style>
</head>
<body>
    <!-- Toast提示 -->
    <div class="toast" id="toast"></div>
    
    <!-- 风险提示弹窗 -->
    <div class="risk-modal" id="riskModal">
        <div class="risk-modal-content">
            <div class="risk-icon">⚠️</div>
            <h2 class="risk-title">投资风险提示</h2>
            <p class="risk-subtitle" style="color: #fbbf24; font-weight: 600;">🎮 本站为投资模拟平台，所有数据仅供学习和娱乐，不构成投资建议</p>
            
            <div class="risk-content">
                <h4>📋 重要提示</h4>
                <ul>
                    <li><strong>本网站为投资模拟游戏平台</strong>，所有股票数据、交易操作均为模拟，不涉及真实资金</li>
                    <li>平台上显示的股票价格、涨跌幅等数据仅供学习和娱乐参考，可能与真实市场存在延迟或差异</li>
                    <li>AI分析和智能诊断功能基于模拟数据生成，不构成任何投资建议或买卖依据</li>
                    <li>用户在平台上的所有操作（买入、卖出、持仓等）均为虚拟交易，不会产生真实的资金往来</li>
                    <li>投资有风险，入市需谨慎。如需真实投资，请咨询持牌专业机构</li>
                </ul>
            </div>
            
            <div class="risk-content" style="border-left-color: #f59e0b; background: rgba(245, 158, 11, 0.1);">
                <h4 style="color: #fcd34d;">⚡ 市场风险教育</h4>
                <ul>
                    <li><strong>黑天鹅事件：</strong>突发重大事件可能导致市场剧烈波动</li>
                    <li><strong>灰犀牛事件：</strong>潜在风险积累可能引发系统性风险</li>
                    <li><strong>政策风险：</strong>监管政策变化可能影响市场走向</li>
                    <li><strong>流动性风险：</strong>极端行情下可能出现买卖困难</li>
                </ul>
            </div>
            
            <div class="risk-actions">
                <button class="btn-disagree" onclick="riskDisagree()">不同意</button>
                <button class="btn-agree" onclick="riskAgree()">我已了解并同意</button>
            </div>
        </div>
    </div>

    <!-- 登录/注册页面 -->
    <div class="auth-page" id="authPage">
        <div class="logo-container">
            <div class="logo">🌍</div>
            <div class="brand-name">ministone</div>
            <div class="tagline">投资模拟平台 · 零风险体验投资乐趣</div>
        </div>
        
        <div class="auth-card">
            <!-- 登录/注册切换 -->
            <div class="auth-tabs">
                <div class="auth-tab active" onclick="switchTab('login')" id="loginTab">登录</div>
                <div class="auth-tab" onclick="switchTab('register')" id="registerTab">注册</div>
            </div>
            
            <!-- 登录表单 -->
            <form id="loginForm" onsubmit="handleLogin(event)">
                <div class="form-group">
                    <label class="form-label">手机号</label>
                    <input type="tel" class="form-input" id="loginPhone" placeholder="请输入手机号" maxlength="11" required>
                </div>
                
                <div class="form-group">
                    <label class="form-label">密码</label>
                    <input type="password" class="form-input" id="loginPassword" placeholder="请输入密码" required>
                </div>
                
                <button type="submit" class="btn-primary" id="loginBtn">
                    立即登录
                </button>
            </form>
            
            <!-- 注册表单 -->
            <form id="registerForm" class="hidden" onsubmit="handleRegister(event)">
                <div class="form-group">
                    <label class="form-label">手机号</label>
                    <input type="tel" class="form-input" id="regPhone" placeholder="请输入11位手机号" maxlength="11" required>
                    <div class="input-hint" id="phoneHint">请输入有效的11位手机号码</div>
                </div>
                
                <div class="form-group">
                    <label class="form-label">真实姓名</label>
                    <input type="text" class="form-input" id="regName" placeholder="请输入真实姓名" required>
                </div>
                
                <div class="form-group">
                    <label class="form-label">身份证号</label>
                    <input type="text" class="form-input" id="regIdCard" placeholder="请输入18位身份证号" maxlength="18" required>
                    <div class="input-hint" id="idCardHint">请输入有效的18位身份证号码</div>
                </div>
                
                <div class="form-group">
                    <label class="form-label">密码</label>
                    <input type="password" class="form-input" id="regPassword" placeholder="9-12位大小写英文+数字" minlength="9" maxlength="12" required>
                    <div class="password-strength" id="passwordStrength">
                        <div class="strength-bar"></div>
                        <div class="strength-bar"></div>
                        <div class="strength-bar"></div>
                    </div>
                    <div class="input-hint" id="passwordHint">密码需包含大小写英文字母和数字，9-12位</div>
                </div>
                
                <div class="form-group">
                    <label class="form-label">确认密码</label>
                    <input type="password" class="form-input" id="regConfirmPassword" placeholder="请再次输入密码" required>
                    <div class="input-hint" id="confirmHint">请再次输入密码确认</div>
                </div>
                
                <button type="submit" class="btn-primary" id="registerBtn">
                    立即注册
                </button>
            </form>
        </div>
    </div>

    <!-- 主页 -->
    <div class="home-page" id="homePage">
        <div class="home-header">
            <div class="header-top">
                <div class="header-title">ministone投资模拟平台</div>
                <div class="header-actions">
                    <div class="header-icon" onclick="showToast('消息功能开发中...')">
                        <i class="fas fa-bell" style="color: white;"></i>
                    </div>
                    <div class="header-icon" onclick="logout()">
                        <i class="fas fa-sign-out-alt" style="color: white;"></i>
                    </div>
                </div>
            </div>
            
            <div style="text-align: center;">
                <div style="font-size: 14px; opacity: 0.8; margin-bottom: 8px;">欢迎回来</div>
                <div style="font-size: 24px; font-weight: 700;" id="userNameDisplay">投资者</div>
            </div>        </div>
        
        <!-- 快捷入口 -->
        <div class="quick-actions">
            <div class="quick-action-card" onclick="location.href='/minirock-v2.html'">
                <div class="quick-action-icon"><i class="fas fa-chart-line"></i></div>
                <div class="quick-action-label">我的持仓</div>
            </div>
            <div class="quick-action-card" onclick="location.href='/portfolio-analysis.html'">
                <div class="quick-action-icon"><i class="fas fa-chart-pie"></i></div>
                <div class="quick-action-label">持仓分析</div>
            </div>
            <div class="quick-action-card" onclick="location.href='/watchlist.html'">
                <div class="quick-action-icon"><i class="fas fa-star"></i></div>
                <div class="quick-action-label">自选股</div>
            </div>
            <div class="quick-action-card" onclick="location.href='/stock-detail.html'">
                <div class="quick-action-icon"><i class="fas fa-robot"></i></div>
                <div class="quick-action-label">AI诊断</div>
            </div>
        </div>
        
        <!-- 市场大盘 -->
        <div class="market-section">
            <div class="section-title">
                <i class="fas fa-chart-line" style="color: #667eea;"></i>
                全球市场
            </div>
            
            <div class="market-grid">
                <!-- A股 -->
                <div class="market-card" onclick="showMarketDetail('A股')">
                    <div class="market-name">上证指数</div>
                    <div class="market-value" id="shIndex">--</div>
                    <div class="market-change" id="shChange">--</div>
                </div>
                <div class="market-card" onclick="showMarketDetail('A股')">
                    <div class="market-name">深证成指</div>
                    <div class="market-value" id="szIndex">--</div>
                    <div class="market-change" id="szChange">--</div>
                </div>
                <div class="market-card" onclick="showMarketDetail('A股')">
                    <div class="market-name">创业板指</div>
                    <div class="market-value" id="cyIndex">--</div>
                    <div class="market-change" id="cyChange">--</div>
                </div>
                
                <!-- 港股 -->
                <div class="market-card" onclick="showMarketDetail('港股')">
                    <div class="market-name">恒生指数</div>
                    <div class="market-value" id="hsIndex">--</div>
                    <div class="market-change" id="hsChange">--</div>
                </div>
                <div class="market-card" onclick="showMarketDetail('港股')">
                    <div class="market-name">恒生科技</div>
                    <div class="market-value" id="hsTechIndex">--</div>
                    <div class="market-change" id="hsTechChange">--</div>
                </div>
                <div class="market-card" onclick="showMarketDetail('港股')">
                    <div class="market-name">国企指数</div>
                    <div class="market-value" id="hsceIndex">--</div>
                    <div class="market-change" id="hsceChange">--</div>
                </div>
                
                <!-- 美股 -->
                <div class="market-card" onclick="showMarketDetail('美股')">
                    <div class="market-name">道琼斯</div>
                    <div class="market-value" id="djIndex">--</div>
                    <div class="market-change" id="djChange">--</div>
                </div>
                <div class="market-card" onclick="showMarketDetail('美股')">
                    <div class="market-name">纳斯达克</div>
                    <div class="market-value" id="nsIndex">--</div>
                    <div class="market-change" id="nsChange">--</div>
                </div>
                <div class="market-card" onclick="showMarketDetail('美股')">
                    <div class="market-name">标普500</div>
                    <div class="market-value" id="spIndex">--</div>
                    <div class="market-change" id="spChange">--</div>
                </div>
            </div>
        </div>
        
        <!-- 新闻区域 -->
        <div class="news-section">
            <div class="section-title">
                <i class="fas fa-newspaper" style="color: #667eea;"></i>
                市场情报
            </div>
            
            <div class="news-tabs">
                <div class="news-tab active" onclick="switchNewsTab('all')">全部</div>
                <div class="news-tab" onclick="switchNewsTab('black-swan')">🦢 黑天鹅</div>
                <div class="news-tab" onclick="switchNewsTab('gray-rhino')">🦏 灰犀牛</div>
                <div class="news-tab" onclick="switchNewsTab('hot')">🔥 热点</div>
            </div>
            
            <div class="news-list" id="newsList">
                <!-- 新闻内容由JS动态加载 -->
                <div class="news-item">
                    <div style="text-align: center; padding: 40px; color: #64748b;">
                        <div class="spinner"></div>
                        <p style="margin-top: 16px;">正在加载新闻...</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- 持仓页面 (默认隐藏) -->
        <div class="portfolio-section hidden" id="portfolioSection">
            <div class="section-title">
                <i class="fas fa-chart-pie" style="color: #667eea;"></i>
                我的持仓
            </div>
            
            <div class="portfolio-header">
                <div class="portfolio-label">总资产</div>
                <div class="portfolio-value" id="totalValue">¥0.00</div>
                <div class="portfolio-change" id="totalChange">
                    <span>--</span>
                </div>
            </div>
            
            <div class="section-title">
                <i class="fas fa-list" style="color: #667eea;"></i>
                持仓明细
            </div>
            
            <div class="news-list" id="portfolioList">
                <div class="news-item" style="text-align: center; padding: 40px; color: #64748b;">
                    <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 16px; opacity: 0.5;"></i>
                    <p>暂无持仓数据</p>
                    <p style="font-size: 12px; margin-top: 8px;">请在个股页面添加关注</p>
                </div>
            </div>
        </div>
        
        <!-- 底部导航栏 -->
        <div class="bottom-nav" id="bottomNav">
            <div class="nav-item active" onclick="switchPage('home')">
                <div class="nav-icon"><i class="fas fa-home"></i></div>
                <div class="nav-label">首页</div>
            </div>
            <div class="nav-item" onclick="switchPage('portfolio')">
                <div class="nav-icon"><i class="fas fa-chart-pie"></i></div>
                <div class="nav-label">持仓</div>
            </div>
            <div class="nav-item" onclick="showToast('AI分析功能开发中...')">
                <div class="nav-icon"><i class="fas fa-robot"></i></div>
                <div class="nav-label">AI</div>
            </div>
            <div class="nav-item" onclick="showToast('个人中心开发中...')">
                <div class="nav-icon"><i class="fas fa-user"></i></div>
                <div class="nav-label">我的</div>
            </div>
        </div>
    </div>

    <script>
        // ==================== 全局状态 ====================
        const API_BASE = window.location.origin.includes('localhost') 
            ? 'http://localhost:8000/api' 
            : '/api';
        
        let currentUser = null;
        let hasAgreedRisk = false;
        let currentNewsTab = 'all';
        
        // ==================== 工具函数 ====================
        function showToast(message, type = 'info') {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.className = `toast ${type}`;
            setTimeout(() => toast.classList.add('show'), 10);
            setTimeout(() => toast.classList.remove('show'), 3000);
        }
        
        function switchTab(tab) {
            document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
            document.getElementById(tab + 'Tab').classList.add('active');
            
            if (tab === 'login') {
                document.getElementById('loginForm').classList.remove('hidden');
                document.getElementById('registerForm').classList.add('hidden');
            } else {
                document.getElementById('loginForm').classList.add('hidden');
                document.getElementById('registerForm').classList.remove('hidden');
            }
        }
        
        // ==================== 验证函数 ====================
        function validatePhone(phone) {
            return /^1[3-9]\d{9}$/.test(phone);
        }
        
        function validateIdCard(idCard) {
            return /^[1-9]\d{5}(18|19|20)\d{2}((0[1-9])|(1[0-2]))(([0-2][1-9])|10|20|30|31)\d{3}[0-9Xx]$/.test(idCard);
        }
        
        function validatePassword(password) {
            // 9-12位，包含大小写字母和数字
            if (password.length < 9 || password.length > 12) return false;
            if (!/[a-z]/.test(password)) return false;
            if (!/[A-Z]/.test(password)) return false;
            if (!/[0-9]/.test(password)) return false;
            return true;
        }
        
        function checkPasswordStrength(password) {
            const bars = document.querySelectorAll('.strength-bar');
            bars.forEach(b => b.className = 'strength-bar');
            
            if (password.length === 0) return;
            
            let strength = 0;
            if (password.length >= 9) strength++;
            if (password.length >= 10) strength++;
            if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
            if (/[0-9]/.test(password)) strength++;
            if (/[^a-zA-Z0-9]/.test(password)) strength++;
            
            const className = strength <= 2 ? 'weak' : strength <= 4 ? 'medium' : 'strong';
            for (let i = 0; i < Math.min(strength, 3); i++) {
                bars[i].classList.add(className);
            }
        }
        
        // 密码输入监听
        document.getElementById('regPassword')?.addEventListener('input', function() {
            checkPasswordStrength(this.value);
        });
        
        // ==================== 带超时的fetch ====================
        async function fetchWithTimeout(url, options = {}, timeout = 3000) {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), timeout);
            
            try {
                const response = await fetch(url, {
                    ...options,
                    signal: controller.signal
                });
                clearTimeout(timeoutId);
                return response;
            } catch (error) {
                clearTimeout(timeoutId);
                if (error.name === 'AbortError') {
                    throw new Error('请求超时');
                }
                throw error;
            }
        }
        
        // ==================== 登录处理 ====================
        async function handleLogin(e) {
            e.preventDefault();
            
            const phone = document.getElementById('loginPhone').value;
            const password = document.getElementById('loginPassword').value;
            
            if (!validatePhone(phone)) {
                showToast('请输入有效的手机号', 'error');
                return;
            }
            
            const btn = document.getElementById('loginBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span>登录中...';
            
            try {
                // 调用登录API（3秒超时）
                const response = await fetchWithTimeout(`${API_BASE}/auth/login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ phone, password })
                }, 3000);
                
                if (response.ok) {
                    const data = await response.json();
                    currentUser = data.user;
                    showToast('登录成功！', 'success');
                    enterHome();
                } else {
                    const error = await response.json();
                    showToast(error.detail || '登录失败，请检查账号密码', 'error');
                }
            } catch (error) {
                console.log('API不可用:', error.message);
                currentUser = { 
                    phone, 
                    name: '投资者',
                    loginTime: Date.now(),
                    expiresIn: 30 * 60 * 1000  // 30分钟过期
                };
                localStorage.setItem('currentUser', JSON.stringify(currentUser));
                showToast('登录成功（离线模式）', 'success');
                enterHome();
            } finally {
                btn.disabled = false;
                btn.innerHTML = '立即登录';
            }
        }
        
        // ==================== 注册处理 ====================
        async function handleRegister(e) {
            e.preventDefault();
            
            const phone = document.getElementById('regPhone').value;
            const name = document.getElementById('regName').value;
            const idCard = document.getElementById('regIdCard').value;
            const password = document.getElementById('regPassword').value;
            const confirmPassword = document.getElementById('regConfirmPassword').value;
            
            // 验证
            if (!validatePhone(phone)) {
                showToast('请输入有效的11位手机号', 'error');
                return;
            }
            
            if (!validateIdCard(idCard)) {
                showToast('请输入有效的18位身份证号', 'error');
                return;
            }
            
            if (!validatePassword(password)) {
                showToast('密码需包含大小写英文字母和数字，9-12位', 'error');
                return;
            }
            
            if (password !== confirmPassword) {
                showToast('两次输入的密码不一致', 'error');
                return;
            }
            
            const btn = document.getElementById('registerBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span>注册中...';
            
            try {
                // 调用注册API（3秒超时）
                const response = await fetchWithTimeout(`${API_BASE}/auth/register`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ phone, name, id_card: idCard, password })
                }, 3000);
                
                if (response.ok) {
                    const data = await response.json();
                    showToast('注册成功！请登录', 'success');
                    switchTab('login');
                    document.getElementById('loginPhone').value = phone;
                } else {
                    const error = await response.json();
                    showToast(error.detail || '注册失败', 'error');
                }
            } catch (error) {
                console.log('API不可用:', error.message);
                // 离线模式 - 保存到本地存储
                const users = JSON.parse(localStorage.getItem('minirock_users') || '[]');
                if (users.find(u => u.phone === phone)) {
                    showToast('该手机号已注册', 'error');
                    btn.disabled = false;
                    btn.innerHTML = '立即注册';
                    return;
                }
                users.push({ phone, name, idCard, password });
                localStorage.setItem('minirock_users', JSON.stringify(users));
                showToast('注册成功（离线模式）', 'success');
                switchTab('login');
                document.getElementById('loginPhone').value = phone;
            } finally {
                btn.disabled = false;
                btn.innerHTML = '立即注册';
            }
        }
        
        // ==================== 进入主页 ====================
        function enterHome() {
            document.getElementById('authPage').style.display = 'none';
            document.getElementById('homePage').style.display = 'block';
            
            // 显示用户名
            if (currentUser?.name) {
                document.getElementById('userNameDisplay').textContent = currentUser.name;
            }
            
            // 显示风险提示弹窗
            if (!hasAgreedRisk && !localStorage.getItem('riskAgreed')) {
                setTimeout(() => {
                    document.getElementById('riskModal').classList.add('show');
                }, 500);
            } else {
                // 直接加载数据
                loadMarketData();
                loadNews();
            }
        }
        
        // ==================== 风险提示处理 ====================
        function riskAgree() {
            hasAgreedRisk = true;
            localStorage.setItem('riskAgreed', 'true');
            document.getElementById('riskModal').classList.remove('show');
            
            // 加载数据
            loadMarketData();
            loadNews();
            showToast('欢迎进入ministone！', 'success');
        }
        
        function riskDisagree() {
            showToast('您需要同意风险提示才能继续使用', 'error');
            // 3秒后返回登录页
            setTimeout(() => {
                logout();
            }, 2000);
        }
        
        // ==================== 加载市场数据 ====================
        async function loadMarketData() {
            const indices = [
                // A股
                { code: '000001.SH', name: 'shIndex', change: 'shChange' },
                { code: '399001.SZ', name: 'szIndex', change: 'szChange' },
                { code: '399006.SZ', name: 'cyIndex', change: 'cyChange' },
                // 港股
                { code: 'HSI', name: 'hsIndex', change: 'hsChange' },
                { code: 'HSTECH', name: 'hsTechIndex', change: 'hsTechChange' },
                { code: 'HSCEI', name: 'hsceIndex', change: 'hsceChange' },
                // 美股
                { code: 'DJI', name: 'djIndex', change: 'djChange' },
                { code: 'IXIC', name: 'nsIndex', change: 'nsChange' },
                { code: 'SPX', name: 'spIndex', change: 'spChange' }
            ];
            
            // 模拟数据（API不可用时使用）
            const mockData = {
                '000001.SH': { close: 3428.15, pct_chg: 0.42 },
                '399001.SZ': { close: 10963.85, pct_chg: -0.18 },
                '399006.SZ': { close: 2156.78, pct_chg: 0.65 },
                'HSI': { close: 23478.32, pct_chg: 1.25 },
                'HSTECH': { close: 5421.68, pct_chg: 2.14 },
                'HSCEI': { close: 8542.15, pct_chg: 0.98 },
                'DJI': { close: 38714.23, pct_chg: -0.32 },
                'IXIC': { close: 15995.32, pct_chg: 0.85 },
                'SPX': { close: 5117.86, pct_chg: 0.23 }
            };
            
            for (const idx of indices) {
                try {
                    const response = await fetch(`${API_BASE}/tushare/quote/${idx.code}`);
                    let data;
                    if (response.ok) {
                        data = await response.json();
                    } else {
                        data = mockData[idx.code];
                    }
                    
                    if (data) {
                        const valueEl = document.getElementById(idx.name);
                        const changeEl = document.getElementById(idx.change);
                        
                        if (valueEl) {
                            valueEl.textContent = data.close ? data.close.toLocaleString('zh-CN', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '--';
                        }
                        if (changeEl) {
                            const pct = data.pct_chg || 0;
                            changeEl.textContent = (pct >= 0 ? '+' : '') + pct.toFixed(2) + '%';
                            changeEl.className = 'market-change ' + (pct >= 0 ? 'up' : 'down');
                        }
                    }
                } catch (e) {
                    // 使用模拟数据
                    const data = mockData[idx.code];
                    if (data) {
                        const valueEl = document.getElementById(idx.name);
                        const changeEl = document.getElementById(idx.change);
                        if (valueEl) valueEl.textContent = data.close.toFixed(2);
                        if (changeEl) {
                            changeEl.textContent = (data.pct_chg >= 0 ? '+' : '') + data.pct_chg.toFixed(2) + '%';
                            changeEl.className = 'market-change ' + (data.pct_chg >= 0 ? 'up' : 'down');
                        }
                    }
                }
            }
        }
        
        // ==================== 页面切换 ====================
        function switchPage(page) {
            // 更新导航栏状态
            document.querySelectorAll('.nav-item').forEach((item, index) => {
                item.classList.remove('active');
                if ((page === 'home' && index === 0) || 
                    (page === 'portfolio' && index === 1)) {
                    item.classList.add('active');
                }
            });
            
            // 隐藏所有页面
            document.querySelector('.market-section').classList.add('hidden');
            document.querySelector('.news-section').classList.add('hidden');
            document.getElementById('portfolioSection').classList.add('hidden');
            
            // 显示对应页面
            if (page === 'home') {
                document.querySelector('.market-section').classList.remove('hidden');
                document.querySelector('.news-section').classList.remove('hidden');
            } else if (page === 'portfolio') {
                document.getElementById('portfolioSection').classList.remove('hidden');
                loadPortfolio();
            }
            
            // 滚动到顶部
            window.scrollTo(0, 0);
        }
        
        // ==================== 持仓数据加载 ====================
        async function loadPortfolio() {
            const container = document.getElementById('portfolioList');
            
            try {
                const response = await fetchWithTimeout(`${API_BASE}/portfolio/`, {}, 3000);
                if (response.ok) {
                    const data = await response.json();
                    if (data && data.holdings && data.holdings.length > 0) {
                        renderPortfolio(data);
                    } else {
                        container.innerHTML = `
                            <div class="news-item" style="text-align: center; padding: 40px; color: #64748b;">
                                <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 16px; opacity: 0.5;"></i>
                                <p>暂无持仓数据</p>
                                <p style="font-size: 12px; margin-top: 8px;">请在个股页面添加关注</p>
                            </div>
                        `;
                    }
                } else {
                    throw new Error('获取持仓失败');
                }
            } catch (e) {
                console.log('持仓API不可用:', e.message);
                // 显示示例数据或空状态
                container.innerHTML = `
                    <div class="news-item" style="text-align: center; padding: 40px; color: #64748b;">
                        <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 16px; opacity: 0.5;"></i>
                        <p>暂无持仓数据</p>
                        <p style="font-size: 12px; margin-top: 8px;">离线模式 - 请在个股页面添加关注</p>
                    </div>
                `;
            }
        }
        
        function renderPortfolio(data) {
            // 更新总资产
            const totalValue = data.total_value || 0;
            const totalCost = data.total_cost || 0;
            const change = totalValue - totalCost;
            const changePercent = totalCost > 0 ? (change / totalCost * 100).toFixed(2) : 0;
            
            document.getElementById('totalValue').textContent = `¥${totalValue.toFixed(2)}`;
            
            const changeEl = document.getElementById('totalChange');
            const isUp = change >= 0;
            changeEl.className = `portfolio-change ${isUp ? 'up' : 'down'}`;
            changeEl.innerHTML = `
                <i class="fas fa-${isUp ? 'arrow-up' : 'arrow-down'}"></i>
                <span>${Math.abs(change).toFixed(2)} (${Math.abs(changePercent).toFixed(2)}%)</span>
            `;
            
            // 渲染持仓列表
            const container = document.getElementById('portfolioList');
            const holdings = data.holdings || [];
            
            container.innerHTML = holdings.map(h => {
                const stockChange = (h.current_price - h.cost_price) * h.quantity;
                const stockChangePercent = h.cost_price > 0 
                    ? ((h.current_price - h.cost_price) / h.cost_price * 100).toFixed(2) 
                    : 0;
                const isStockUp = stockChange >= 0;
                
                return `
                    <div class="news-item" onclick="showStockDetail('${h.symbol}')" style="cursor: pointer;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                            <div>
                                <div style="font-weight: 600; font-size: 16px;">${h.name || h.symbol}</div>
                                <div style="font-size: 12px; color: #64748b;">${h.symbol}</div>
                            </div>
                            <div style="text-align: right;">
                                <div style="font-weight: 700; font-size: 18px;">¥${h.current_price?.toFixed(2) || '--'}</div>
                                <div style="font-size: 12px; color: ${isStockUp ? '#ff6b6b' : '#51cf66'};">
                                    ${isStockUp ? '+' : ''}${stockChangePercent}%
                                </div>
                            </div>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 12px; color: #64748b;">
                            <span>持仓: ${h.quantity}股</span>
                            <span>成本: ¥${h.cost_price?.toFixed(2) || '--'}</span>
                            <span>盈亏: ${isStockUp ? '+' : ''}¥${stockChange.toFixed(2)}</span>
                        </div>
                    </div>
                `;
            }).join('');
        }
        
        function showStockDetail(symbol) {
            showToast(`查看 ${symbol} 详情 - 功能开发中...`);
        }
        let newsData = [
            {
                tag: 'black-swan',
                tagName: '黑天鹅',
                title: '美联储突发降息50基点，全球金融市场剧烈震荡，新兴市场资产价格大幅波动',
                source: '财联社',
                time: '2小时前'
            },
            {
                tag: 'gray-rhino',
                tagName: '灰犀牛',
                title: '美债收益率持续攀升，全球债务风险累积，专家警告系统性风险正在积聚',
                source: '华尔街见闻',
                time: '3小时前'
            },
            {
                tag: 'hot',
                tagName: '热点',
                title: 'AI算力需求爆发，相关产业链公司订单激增，半导体板块集体上涨',
                source: '证券时报',
                time: '4小时前'
            },
            {
                tag: 'black-swan',
                tagName: '黑天鹅',
                title: '某大型银行财报暴雷，股价暴跌25%，引发金融股连锁反应',
                source: '彭博社',
                time: '5小时前'
            },
            {
                tag: 'gray-rhino',
                tagName: '灰犀牛',
                title: '房地产债务问题持续发酵，多家房企面临流动性压力，行业出清加速',
                source: '经济观察报',
                time: '6小时前'
            },
            {
                tag: 'hot',
                tagName: '热点',
                title: '新能源汽车销量创新高，锂电产业链景气度回升，龙头公司业绩超预期',
                source: '券商中国',
                time: '7小时前'
            },
            {
                tag: 'gray-rhino',
                tagName: '灰犀牛',
                title: '地缘政治风险升温，原油价格大幅波动，能源安全议题再受关注',
                source: 'Reuters',
                time: '8小时前'
            }
        ];
        
        async function loadNews() {
            const container = document.getElementById('newsList');
            container.innerHTML = `
                <div class="news-item">
                    <div style="text-align: center; padding: 40px; color: #64748b;">
                        <div class="spinner"></div>
                        <p style="margin-top: 16px;">正在加载新闻...</p>
                    </div>
                </div>
            `;
            
            try {
                // 尝试从新加坡API获取新闻（添加尾部斜杠）
                const response = await fetchWithTimeout(`${API_BASE}/news/?limit=20`, {}, 3000);
                if (response.ok) {
                    const data = await response.json();
                    if (data && data.length > 0) {
                        newsData = data.map(item => ({
                            tag: item.category || 'hot',
                            tagName: getTagName(item.category),
                            title: item.title,
                            source: item.source || '新闻源',
                            time: formatTime(item.published_at)
                        }));
                        renderNews();
                        return;
                    }
                }
            } catch (e) {
                console.log('新闻API不可用:', e.message);
            }
            
            // 使用默认示例数据
            renderNews();
        }
        
        function getTagName(category) {
            const tagMap = {
                'black-swan': '黑天鹅',
                'gray-rhino': '灰犀牛',
                'hot': '热点',
                'important': '重要',
                'policy': '政策'
            };
            return tagMap[category] || '热点';
        }
        
        function formatTime(timestamp) {
            if (!timestamp) return '刚刚';
            const date = new Date(timestamp);
            const now = new Date();
            const diff = Math.floor((now - date) / 1000 / 60); // 分钟
            
            if (diff < 60) return `${diff}分钟前`;
            if (diff < 1440) return `${Math.floor(diff / 60)}小时前`;
            return `${Math.floor(diff / 1440)}天前`;
        }
        
        function switchNewsTab(tab) {
            currentNewsTab = tab;
            document.querySelectorAll('.news-tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
            renderNews();
        }
        
        function renderNews() {
            const container = document.getElementById('newsList');
            
            let filteredNews = newsData;
            if (currentNewsTab !== 'all') {
                filteredNews = newsData.filter(n => n.tag === currentNewsTab);
            }
            
            if (filteredNews.length === 0) {
                container.innerHTML = `
                    <div class="news-item">
                        <div style="text-align: center; padding: 20px; color: #64748b;">
                            暂无相关新闻
                        </div>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = filteredNews.map(news => `
                <div class="news-item" onclick="showToast('新闻详情功能开发中...')">
                    <span class="news-tag ${news.tag}">${news.tagName}</span>
                    <div class="news-title">${news.title}</div>
                    <div class="news-meta">
                        <span>${news.source}</span>
                        <span>${news.time}</span>
                    </div>
                </div>
            `).join('');
        }
        
        function showMarketDetail(market) {
            showToast(`${market}详情功能开发中...`);
        }
        
        function logout() {
            currentUser = null;
            hasAgreedRisk = false;
            document.getElementById('homePage').style.display = 'none';
            document.getElementById('authPage').style.display = 'flex';
            document.getElementById('loginForm').reset();
            document.getElementById('registerForm').reset();
            showToast('已退出登录');
        }
        
        // ==================== 初始化 ====================
        document.addEventListener('DOMContentLoaded', () => {
            // 检查是否已登录
            const savedUser = localStorage.getItem('currentUser');
            if (savedUser) {
                const user = JSON.parse(savedUser);
                // 检查session是否过期
                if (user.loginTime && (Date.now() - user.loginTime) < (user.expiresIn || 30 * 60 * 1000)) {
                    currentUser = user;
                    // 自动续期
                    currentUser.loginTime = Date.now();
                    localStorage.setItem('currentUser', JSON.stringify(currentUser));
                } else {
                    // Session过期，清除登录状态
                    localStorage.removeItem('currentUser');
                    showToast('登录已过期，请重新登录', 'warning');
                }
            }
        });
    </script>
</body>
</html>
